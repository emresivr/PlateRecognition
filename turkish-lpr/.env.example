# =============================================================================
# Turkish LPR — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by pydantic-settings on startup.
# NEVER commit .env to version control — it contains credentials.
# =============================================================================

# ── RTSP Camera ─────────────────────────────────────────────────────────────
RTSP_USER=admin
RTSP_PASS=Panasonic1
RTSP_HOST=192.168.1.68
RTSP_PORT=554
RTSP_PATH=MediaInput/stream_1

# ── RTSP Stability ──────────────────────────────────────────────────────────
# Force TCP transport (critical for dual-NIC Windows setups)
RTSP_TRANSPORT=tcp
# Seconds between reconnection attempts
RTSP_RECONNECT_DELAY=3
# Consecutive read failures before triggering a reconnect
RTSP_MAX_FAILURES=30

# ── Plate Detector (FastALPR) ──────────────────────────────────────────────
# FastALPR detector model name (ONNX, auto-downloaded on first use)
# See: https://github.com/ankandrew/open-image-models
DETECTOR_MODEL_NAME=yolo-v9-t-384-license-plate-end2end
# Minimum confidence score to accept a detection (0.0–1.0)
DETECTOR_CONFIDENCE=0.25

# ── OCR (FastALPR) ─────────────────────────────────────────────────────────
# FastALPR OCR model name (ONNX, auto-downloaded on first use)
# See: https://github.com/ankandrew/fast-plate-ocr
OCR_MODEL_NAME=global-plates-mobile-vit-v2-model
# Padding ratio around detected plate before OCR (0.0 = no padding, 0.2 = 20%)
OCR_PAD_RATIO=0.15

# ── Multi-frame Voting ──────────────────────────────────────────────────────
# Number of frames to capture per vehicle event
VOTING_FRAME_COUNT=5
# Minimum agreement ratio to accept a plate reading
VOTING_MIN_AGREEMENT=0.6

# ── Storage ─────────────────────────────────────────────────────────────────
# SQLite database path (relative to project root)
DB_PATH=data/plates.db

# ── Privacy ─────────────────────────────────────────────────────────────────
# Save cropped plate images to disk? (true/false)
# Default is false for privacy. Enable only if you need training data.
SAVE_PLATE_IMAGES=false
# Directory for saved plate images (only used when SAVE_PLATE_IMAGES=true)
PLATE_IMAGE_DIR=data/plates

# ── Logging ─────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
